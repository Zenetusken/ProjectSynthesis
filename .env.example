# PromptForge v2 Environment Variables
# Copy this to .env and fill in values

# LLM Provider (at least one required)
# Option A: Claude Code CLI with Max subscription (preferred, zero cost)
#   Install: npm install -g @anthropic-ai/claude-code
#   Auth: claude login
# Option B: Anthropic API key
ANTHROPIC_API_KEY=

# GitHub Integration (optional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Security
SECRET_KEY=promptforge-dev-secret-key-change-in-production
GITHUB_TOKEN_ENCRYPTION_KEY=

# MCP Server
MCP_PORT=8001
MCP_HOST=127.0.0.1

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/promptforge.db
